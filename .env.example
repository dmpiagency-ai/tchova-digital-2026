# ============================================
# TCHOVA DIGITAL - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to Git!

# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Emulators
VITE_USE_FIREBASE_EMULATOR=false

# App
VITE_APP_NAME=TchovaDigital
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://tchovadigital.com

# WhatsApp
VITE_WHATSAPP_NUMBER=258879097249

# Analytics
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FACEBOOK_PIXEL_ID=123456789012345
VITE_ANALYTICS_DEBUG=false
VITE_DISABLE_ANALYTICS=false

# Feature Flags
VITE_ENABLE_LOGIN=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_ADMIN=true
VITE_ENABLE_GSM_FEATURES=true
VITE_ENABLE_AI=true