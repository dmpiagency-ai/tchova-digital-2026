# ============================================
# TCHOVA DIGITAL - CONFIGURAÇÃO LOCAL
# ============================================
# Copie este arquivo para .env.local e configure
# NUNCA faça commit deste arquivo para o Git!

# ============================================
# FIREBASE CONFIGURATION (OBRIGATÓRIO)
# ============================================
# Obtido em: Firebase Console > Project Settings > Your Apps

VITE_FIREBASE_API_KEY=AIzaSy_EXEMPLO_DE_API_KEY_VALIDA_39chars
VITE_FIREBASE_AUTH_DOMAIN=tchova-digital.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tchova-digital
VITE_FIREBASE_STORAGE_BUCKET=tchova-digital.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ============================================
# WHATSAPP (Público - pode estar no .env)
# ============================================
VITE_WHATSAPP_NUMBER=258879097249

# ============================================
# GSM SITES
# ============================================
VITE_GSM_SITE_URL=https://gsm.tchova.digital

# ============================================
# PAYMENT PROVIDERS (Opcional)
# ============================================
VITE_MPESA_SHORTCODE=1234
VITE_EMOLA_MERCHANT_ID=TCHOVA001

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Emails separados por vírgula que terão acesso admin
VITE_ADMIN_EMAILS=admin@tchova.digital,gestor@tchova.digital

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_LOGIN=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_ADMIN_PANEL=false
VITE_ENABLE_GSM_FEATURES=true
